using namespace std;


int n, k;
struct Song
{
	long long length;
	long long beauty;
	
    bool operator < (const Song &a) const {
        return this->length > a.length;//ïŋ―ïŋ―ÐĄÖĩïŋ―ïŋ―ïŋ―ïŋ―
    }
};
Song songs[300010];

bool compareBeauty(const Song &a, const Song &b)
{
	if (a.beauty == b.beauty)
		return a.length > b.length;
	else
		return a.beauty > b.beauty;
}

std::priority_queue<Song> q;	//ïŋ―ïŋ―Į°kïŋ―ïŋ―ïŋ―ÄļčĢŽïŋ―ïŋ―ÐĄïŋ―ŅĢïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―Į·ïŋ―Î§ïŋ―ïŋ―ïŋ―ïŋ―Ėĩïŋ― 

int main()
{
	scanf("%d%d", &n, &k);
	for (int i = 0 ; i < n ; i++)
		scanf("%I64d%I64d", &(songs[i].length), &(songs[i].beauty));
		
	sort(songs, songs + n, compareBeauty);	//ïŋ―ïŋ―Beautyïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ― 
	
	long long maxPleasure = 0;
	long long curLength = 0;
	long long curBeauty = 100000000;
	long long curPleasure; 
	for (int i = 0 ; i < k ; i++)	//Öŧïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ― 
	{
		curLength = curLength + songs[i].length;
		if (curBeauty > songs[i].beauty)
			curBeauty = songs[i].beauty;	//Öŧïŋ―ïŋ―Ô―ïŋ―ïŋ―Ô―ÐĄ 
		
		curPleasure = curBeauty * curLength;
		if (maxPleasure < curPleasure)
			maxPleasure = curPleasure;
		
		q.push(songs[i]);
	}
	
	for (int i = k ; i < n ; i++)	//ïŋ―ïŋ―1ïŋ―ïŋ―1
	{
		//ïŋ―ïŋ―ïŋ―Øĩïŋ―ïŋ―ïŋ―Ãŋïŋ―Îģïŋ―ïŋ―ïŋ―ïŋ―Äŧáēŧïŋ―ïŋ―ïŋ―ĮąČ―ïŋ―ÐĄïŋ―ïŋ―
		//ïŋ―ïŋ―ïŋ―ïŋ―ÐąČ―Ïīïŋ―ïŋ―ïŋ―ÏĩÄŋïŋ―ïŋ―Üīïŋ―ïŋ―ÚĢïŋ―ïŋ―ïŋ―ïŋ―Ņūïŋ―ïŋ―ïŋ―Į°ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ― 
		
		curLength = curLength + songs[i].length;
		if (curBeauty > songs[i].beauty)
			curBeauty = songs[i].beauty;	//Öŧïŋ―ïŋ―Ô―ïŋ―ïŋ―Ô―ÐĄ 
		q.push(songs[i]);
		Song curSong = q.top();
		q.pop();
		curLength = curLength - curSong.length;	//ïŋ―ïŋ―Ėĩïŋ― 
		
		curPleasure = curBeauty * curLength;
		if (maxPleasure < curPleasure)
			maxPleasure = curPleasure;
	} 
	
	printf("%I64d\n", maxPleasure);
	
	return 0;
}

