#include <cstdio>
#include <cstring>
#include <algorithm>
#include <vector>
#include <queue>
#include <map>
#include <iterator>
#include <cmath>

using namespace std;

int n;

int d[150];
int isUsed[150];
int x, y;

bool compare(const int &a, const int &b)
{
	return a < b;
}

int main()
{
	scanf("%d", &n);
	for (int i = 0 ; i < n ; i++)
		scanf("%d", &(d[i]));
		
	sort(d, d + n, compare);
	
	memset(isUsed, false, sizeof(isUsed));
	x = d[n - 1];
	if (x != 1)
	{
		isUsed[n - 1] = true;
		isUsed[0] = true;
	}
	else
	{
		isUsed[0] = true;
	}
	
	int l = 1, r = n - 2;
	
	for (int dd = 2 ; dd <= x - 1 ; dd++)
	{
		if (x % dd == 0)
		{
			int xdd = x / dd;
			if (dd > xdd)
			{
				break;
			}
			
			if (dd != xdd)	//าช๏ฟฝ๏ฟฝ๏ฟฝาป๏ฟฝ๏ฟฝฦฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝัณิต๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝำต๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝหต4๏ฟฝ๏ฟฝ1,2,4๏ฟฝ๏ฟฝ ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝฯป๏ฟฝ๏ฟฝษฐ๏ฟฝ1,2,2,4๏ฟฝิต๏ฟฝ 
			{
				while (d[l] != dd)	//๏ฟฝ๏ฟฝ๏ฟฝรฟ๏ฟฝ๏ฟฝวฒ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝฺตฤฟ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ 
					l++;
				isUsed[l] = true;
				l++;
			}
							
			while (d[r] != xdd)
				r--;
			isUsed[r] = true;
			r--;
		}
	}
	
	int p = n - 1;
	while (p >= 0)
	{
		if (isUsed[p] == false)
		{
			y = d[p];
			break;			
		}
		p--;
	}
	
	printf("%d %d\n", x, y);

	return 0;
}

