void swap(int &a, int &b)
{
     int temp = a;
     a = b;
     b = temp;
}

int doGcd(int a, int b)
{
     if (a % b == 0)
          return b;
     else
          return doGcd(b, a % b);
}

int gcd(int a, int b)
{
     if (b < a)
          swap(a, b);
     return doGcd(a, b);
}

