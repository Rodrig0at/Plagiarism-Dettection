void update(int o, int l, int r, int ind, int ans)
{
     if(l == r) //魹ｽ魹ｽ魹ｽ魹ｽﾇｰ魹ｽ魹ｽ魹ｽﾂｵ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾒｶﾋｵ魹ｽ魹ｽ魹ｽﾈｼ魹ｽ魹ｽ魹ｽﾒｶ魹ｽﾓｽ魹ｽ魹ｽﾊｱ魹ｽ魹ｽﾖｱ魹ｽﾓｸ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾏ｢魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ
     {
          st[o] = ans;
          return;
     }
     
     int m = l + ((r - l) >> 1);
     if (ind <= m)   //魹ｽ魹ｽ魹ｽ魹ｽﾒｪ魹ｽ魹ｽ魹ｽﾂｵ魹ｽﾒｶ魹ｽﾓｽ魹ｽ魹ｽ魹ｽﾚｵ魹ｽﾇｰ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾓｽ魹ｽ魹ｽﾄｷ魹ｽﾎｧ魹ｽﾚ｣魹ｽ魹ｽ魹ｽﾝｹ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾓｽ魹ｽ罐ｬ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾒｶ魹ｽ魹ｽﾓｽ魹ｽ魹ｽ
     {
          update(o << 1, l, m, ind, ans);
     }
     else
     {
          update((o << 1) | 1, m + 1, r, ind, ans);
     }
     st[o] = gcd(st[o << 1], st[(o << 1) | 1]);//魹ｽﾝｹ魹ｽ魹ｽﾖｮ魹ｽ魹ｽ魹ｽﾃｶ魹ｽ魹ｽﾓｽ魹ｽ魹ｽ魹ｽ魹ｽﾂｸ魹ｽ魹ｽﾚｵ罐ｨ魹ｽﾋｴ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾖｵ魹ｽ魹ｽ
}

