#include <cstdio>
#include <cstdlib>
#include <cstring>
#include <vector>

using namespace std;

const int MOD = 998244353;

//dp
int f[1010][2020][4];	//i--๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝj--๏ฟฝ๏ฟฝวฐ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ4--๏ฟฝ๏ฟฝ๏ฟฝาป๏ฟฝะตฤธ๏ฟฝ๏ฟฝ๏ฟฝ 
//0--ศซ๏ฟฝืฃ๏ฟฝ1--๏ฟฝฯฐ๏ฟฝ๏ฟฝยบฺฃ๏ฟฝ2--๏ฟฝฯบ๏ฟฝ๏ฟฝยฐืฃ๏ฟฝ3--ศซ๏ฟฝ๏ฟฝ 

//ำณ๏ฟฝ๏ฟฝ๏ฟฝฯต๏ฟฝ๏ฟฝi--วฐฮป๏ฟฝ๏ฟฝj--๏ฟฝ๏ฟฝฮป 
int d[4][4] = {{0, 1, 1, 1}, 
               {0, 0, 2, 0}, 
			   {0, 2, 0, 0}, 
			   {1, 1, 1, 0}};
			   
int n, k;

int main()
{
	scanf("%d%d", &n, &k);
	
	f[1][1][0] = 1;
	f[1][2][1] = 1;
	f[1][2][2] = 1;
	f[1][1][3] = 1;
	
	for (int i = 2 ; i <= n ; i++)
	{
		int limit = i * 2;
		for (int j = 1 ; j <= limit ; j++)
		{
			for (int k1 = 0 ; k1 < 4 ; k1++)	//วฐฮป
				for (int k2 = 0 ; k2 < 4 ; k2++) 	//๏ฟฝ๏ฟฝฮป 
				{
					int step = d[k1][k2];
					int former = j - step;
					
					if (former < 1)	//๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ 
						continue;
						
					f[i][j][k2] = (f[i][j][k2] + f[i-1][former][k1]) % MOD;
				}
		}
	}
	
	int ans = 0;
	for (int i = 0 ; i < 4 ; i++)
	{
		ans = (ans + f[n][k][i]) % MOD;
	}
	
	printf("%d\n", ans);
	
	return 0;
}

