typedef long double ld;
const ld eps=1e-8;
const ld pi=acos(-1.0);
int sgn(ld x)
{
    if (x<-eps) return -1;
    if (x>eps) return 1;
    return 0;
}
 
struct P; //๏ฟฝใฃฌ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ
