#include <cstdio>
#include <cmath>

int main()
{
	int a, b;
	
	scanf("%d%d", &a, &b);
	
	
	int na = (int)sqrt(a);
	while ((na + 1) * (na + 1)  <= a)
		na++;
		
	int nb = (int)sqrt(b) - 1;
	while ((nb + 2) * (nb + 1)  <= b)
		nb++;
	
	//printf("%d %d\n", na, nb);
	if (na <= nb)
	{
		printf("Vladik\n");
	}
	else
		printf("Valera\n");
	
	
	
	
	
	return 0;
}
